  "keyFeatures": [
    "TLS fingerprinting to mimic Chrome, Firefox, Safari, and other browsers",
    "Full HTTP/1.1, HTTP/2, and HTTP/3 protocol support with automatic negotiation",
    "Protocol racing (Happy Eyeballs) between HTTP/2 and HTTP/3",
    "Custom HTTP header ordering for accurate browser emulation",
    "WebSocket support with consistent TLS fingerprinting",
    "HTTP and SOCKS5 proxy support with authentication",
    "Built-in cookie jar management",
    "Certificate pinning for enhanced security",
    "Bandwidth tracking for monitoring upload/download usage",
    "Language bindings for JavaScript (Node.js), Python, and C# via FFI"
  ],
